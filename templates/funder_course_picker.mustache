{{!
    @template local_esmed_compliance/funder_course_picker

    Picker used when the operator clicks "Link a new course" — lists every
    course that does not already have a funder link. Clicking a row jumps
    straight to the edit form in create mode.

    Context variables:
      * baseurl    — absolute URL of funders.php
      * courses    — array of { id, fullname, shortname }
      * has_courses — boolean
}}
<section class="esmed-funder-picker">
    <p>
        <a href="{{baseurl}}">
            &laquo; {{#str}} funders_back_to_list, local_esmed_compliance {{/str}}
        </a>
    </p>

    {{#has_courses}}
        <table class="generaltable">
            <thead>
                <tr>
                    <th scope="col">{{#str}} funders_col_course, local_esmed_compliance {{/str}}</th>
                    <th scope="col">{{#str}} attestations_col_shortname, local_esmed_compliance {{/str}}</th>
                    <th scope="col"><span class="sr-only">{{#str}} funders_col_actions, local_esmed_compliance {{/str}}</span></th>
                </tr>
            </thead>
            <tbody>
                {{#courses}}
                    <tr>
                        <td>{{fullname}}</td>
                        <td>{{shortname}}</td>
                        <td>
                            <a class="btn btn-primary btn-sm"
                               href="{{baseurl}}?action=edit&amp;courseid={{id}}">
                                {{#str}} funders_picker_link, local_esmed_compliance {{/str}}
                            </a>
                        </td>
                    </tr>
                {{/courses}}
            </tbody>
        </table>
    {{/has_courses}}
    {{^has_courses}}
        <p><em>{{#str}} funders_picker_all_linked, local_esmed_compliance {{/str}}</em></p>
    {{/has_courses}}
</section>
